# =============================================================================
# muselab — environment variables
# Copy to .env and edit. All paths can be absolute or relative to compose dir.
# =============================================================================

# --- Required ---
# Long random string. Single-user auth token.
#   Linux/macOS:  openssl rand -hex 32
#   Windows PS:   -join ((1..64) | % { '{0:x}' -f (Get-Random -Max 16) })
MUSELAB_TOKEN=change-me-to-a-long-random-string

# --- Docker compose ---
# Host directory exposed to the portal. Inside the container always /data.
#   Linux/macOS:  /home/you/notes
#   Windows:      C:/Users/you/notes
ARCHIVE_DIR=./data

# Host location of Claude CLI credentials (from `claude login`).
# Linux/macOS auto-detected via ${HOME}/.claude.
# Windows must set explicitly, e.g. C:/Users/you/.claude
# CLAUDE_HOME=C:/Users/you/.claude

# --- Optional ---
# Host port (container always listens on 8765).
MUSELAB_PORT=8765

# Host interface to bind. Defaults to 127.0.0.1 = localhost-only (safe default
# for the per-OS desktop installers). Set to 0.0.0.0 to expose on LAN/VPS —
# then you MUST also open the firewall and trust everyone on that network with
# your MUSELAB_TOKEN. Docker compose always binds 0.0.0.0 inside the container
# (irrelevant here; just don't `ports:` to a public interface on the host).
MUSELAB_HOST=127.0.0.1

# Default model (per-session picker overrides).
MUSELAB_MODEL=claude-sonnet-4-6

# --- Optional: alternative providers (Anthropic-compatible endpoints) ---
# Set any to enable that provider in the model picker. All routed via the
# claude-agent-sdk directly — vendor must expose an `/anthropic` endpoint
# (DeepSeek / GLM / MiniMax all do). Full SDK feature parity: tools, MCP,
# skills, streaming, thinking — same loop as Anthropic, just different host.
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=         # 智谱 GLM-4.7 / GLM-5
MINIMAX_API_KEY=         # MiniMax M2.7
# Kimi (Moonshot) was removed 2026-05-17 — vendor's Anthropic endpoint
# behaviour was inconsistent in muselab testing; re-add when stable.
# 小米 MiMo / Qwen 目前只提供 OpenAI 兼容接口，没有 Anthropic 兼容端点，暂不支持
# Optional base URL overrides for self-hosted / proxied / regional mirrors.
# These point at each vendor's Anthropic-compatible endpoint (not /v1 OpenAI).
# Leave blank to use the public default; set to a full URL to redirect every
# stream + probe call. Takes effect on the next stream — no restart needed.
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# --- Native (non-Docker) only ---
# Absolute host path of the archive root when running `uvicorn ...` directly.
# Ignored when running via docker-compose.
MUSELAB_ROOT=/home/you/notes
